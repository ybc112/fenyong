# BSC Testnet deployment config
# Copy this file to .env, then fill PRIVATE_KEY before running npm run deploy:testnet.

BSC_TESTNET_RPC_URL=https://data-seed-prebsc-1-s1.binance.org:8545/
PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# NBT token constructor args
TOKEN_NAME=NBT
TOKEN_SYMBOL=NBT
INITIAL_SUPPLY=200000000

# Optional. Leave empty to use deployer address.
FEE_RECEIVER=

# Optional. Staking deposit fee receiver. Can be changed after deployment.
DEPOSIT_FEE=
DEPOSIT_FEE_RECEIVER=

# Optional. Set if you already have a PancakeSwap pair on testnet.
NBT_PAIR=

# Optional. If greater than 0, script approves and funds the staking reward pool after deployment.
INITIAL_REWARD_FUND=0

# Optional output paths. Defaults are safe for this repo.
FRONTEND_ENV_PATH=frontend 3/.env
DEPLOYMENTS_DIR=deployments
